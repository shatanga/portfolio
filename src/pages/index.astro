---
import Base from '../layouts/Base.astro';
import { site, links } from '../config.js';
import projects from '../data/projects.json';

const base = import.meta.env.BASE_URL;
const countries = [...new Set(projects.map((p) => p.country).filter(Boolean))].sort();
const totalPhotos = projects.reduce((n, p) => n + p.count, 0);
---

<Base description={site.tagline}>
  <section class="hero hero--split">
    {site.photo && (
      <div class="hero-photo">
        <img src={`${base}${site.photo}`} alt={site.name} width="360" height="360" fetchpriority="high" />
      </div>
    )}
    <div class="hero-text">
      <h1>{site.name}</h1>
      <p class="role">{site.title}</p>
      <p class="tagline">{site.tagline}</p>
      {site.education && <p class="edu">🎓 {site.education}</p>}
      <div class="cta-row">
        <a class="btn primary" href={links.cv} target="_blank" rel="noopener">Download CV ↗</a>
        <a class="btn" href={links.certificates} target="_blank" rel="noopener">Certificates ↗</a>
        <a class="btn" href={`${base}contact`}>Contact</a>
      </div>
    </div>
  </section>

  <div class="toolbar" id="filter">
    <span class="label">{projects.length} projects · {totalPhotos} photos</span>
    <button class="chip" data-country="all" aria-pressed="true">All</button>
    {countries.map((c) => <button class="chip" data-country={c} aria-pressed="false">{c}</button>)}
  </div>

  <section class="grid" id="grid">
    {projects.map((p) => (
      <article class="card" data-country={p.country}>
        <a href={`${base}projects/${p.slug}`}>
          <div class="thumb">
            <img src={`${base}${p.cover}`} alt={`${p.factory} — ${p.type}`} loading="lazy" width="700" height="525" />
          </div>
          <div class="body">
            <h3>{p.factory}</h3>
            <div class="meta">
              {p.country && <span class="badge country">{p.country}</span>}
              {(p.types ?? []).map((t) => <span class="badge">{t}</span>)}
            </div>
            {p.yearFrom && <p class="count">{p.yearFrom === p.yearTo ? p.yearFrom : `${p.yearFrom}–${p.yearTo}`}</p>}
          </div>
        </a>
      </article>
    ))}
  </section>
</Base>

<script>
  const bar = document.getElementById('filter');
  const cards = [...document.querySelectorAll('#grid .card')];
  bar?.addEventListener('click', (e) => {
    const btn = e.target.closest('.chip');
    if (!btn) return;
    const country = btn.dataset.country;
    bar.querySelectorAll('.chip').forEach((c) => c.setAttribute('aria-pressed', String(c === btn)));
    cards.forEach((card) => {
      card.style.display = country === 'all' || card.dataset.country === country ? '' : 'none';
    });
  });
</script>
