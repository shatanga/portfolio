---
import Base from '../layouts/Base.astro';
import { links } from '../config.js';
import groups from '../data/certificates.json';

const openish = new Set(['Unlimited']);
---

<Base
  title="Certificates"
  description="Site-safety, machinery-operation and welding certificates held by Zdenek Otcenasek."
>
  <div class="cert-wrap">
    <header class="cert-head">
      <h1>Certificates</h1>
      <a class="btn primary" href={links.certificates} target="_blank" rel="noopener"
        >↓ Download scans (Google Drive)</a
      >
    </header>

    {groups.map((group) => (
      <section class="cert-section">
        <h2>{group.title}</h2>
        {group.subgroups.map((sg) => (
          <div class="cert-group">
            <h3>{sg.region}</h3>
            <ul class="cert-list">
              {sg.items.map((it) => (
                <li>
                  <span class="c-name">{it.name}</span>
                  <span class={`c-valid${openish.has(it.valid) ? ' open' : ''}`}>{it.valid}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    ))}
  </div>
</Base>
