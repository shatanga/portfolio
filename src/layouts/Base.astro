---
import { site } from '../config.js';
import '../styles/global.css';

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — Portfolio`;
const nav = [
  { href: base, label: 'Portfolio' },
  { href: `${base}contact`, label: 'Contact' },
];
// normalise current path for active-link matching
const here = Astro.url.pathname.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? site.tagline} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand-name">{site.name}</span>
        <span class="brand-role">Construction Supervisor · Mechanical Fitter · Welder</span>
      </a>
      <nav class="site-nav">
        {nav.map((n) => {
          const target = n.href.replace(/\/$/, '');
          const active = here === target;
          return <a href={n.href} class={active ? 'active' : ''}>{n.label}</a>;
        })}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {site.name}</p>
      <p class="footer-links">
        <a href={`${base}contact`}>Contact</a>
      </p>
    </footer>
  </body>
</html>
